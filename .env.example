# ─── 平台配置 ───
# 可以同时启用多个平台，只需配置对应的凭证即可
# - 配置了 FEISHU_APP_ID 和 FEISHU_APP_SECRET 即启用飞书
# - 配置了 TELEGRAM_BOT_TOKEN 即启用 Telegram
# - 配置了 WECOM_BOT_ID 和 WECOM_BOT_SECRET 即启用企业微信

# 飞书应用凭证
# 需要在飞书开放平台为应用开通以下权限：
#   - im:message:send_as_bot    以应用身份发消息
#   - im:message                获取与发送单聊、群组消息
#   - im:message:patch_as_bot   更新应用发送的消息（权限卡片更新）
#   - im:resource               上传和下载图片/文件资源
#   - cardkit:card              创建与更新 CardKit 卡片（流式输出必需）
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret

# Telegram Bot Token（通过 @BotFather 获取）
TELEGRAM_BOT_TOKEN=your_bot_token

# 企业微信机器人凭证
# 在企业微信管理后台创建智能机器人应用后获取
# 配置指南：https://open.work.weixin.qq.com/help2/pc/21661
WECOM_BOT_ID=your_bot_id
WECOM_BOT_SECRET=your_bot_secret

# ─── 访问控制 ───

# 白名单用户 ID（逗号分隔，留空表示不限制）
# 飞书: open_id（如 ou_xxxx）
# Telegram: 数字 ID（如 123456789）
# 企业微信: userid（如 zhangsan）
ALLOWED_USER_IDS=

# ─── Claude CLI ───

# Claude CLI 可执行文件路径（默认 claude）
CLAUDE_CLI_PATH=claude

# 默认工作目录（默认为当前目录）
CLAUDE_WORK_DIR=.

# 允许 /cd 切换的基础目录（逗号分隔，留空则限制在 CLAUDE_WORK_DIR 下）
ALLOWED_BASE_DIRS=

# 是否跳过权限确认（默认 false，生产环境建议保持 false）
CLAUDE_SKIP_PERMISSIONS=false

# 执行超时（毫秒，默认 600000 即 10 分钟）
CLAUDE_TIMEOUT_MS=600000

# 模型（可选，如 sonnet、opus、haiku 或完整模型名，可被用户 /model 命令覆盖）
# CLAUDE_MODEL=

# 代理地址（可选，传递给 Claude CLI 子进程的 HTTPS_PROXY/HTTP_PROXY）
# PROXY_URL=http://127.0.0.1:7890

# ─── 权限 Hook ───

# 权限确认 Hook 服务端口（默认 18900，仅 CLAUDE_SKIP_PERMISSIONS=false 时使用）
HOOK_SERVER_PORT=18900

# ─── 日志 ───

# 日志文件存储目录（默认 ~/.cc-im/logs）
# LOG_DIR=

# 日志等级：DEBUG / INFO / WARN / ERROR（默认 DEBUG）
# LOG_LEVEL=DEBUG
